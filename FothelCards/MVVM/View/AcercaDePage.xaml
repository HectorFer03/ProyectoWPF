<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="FothelCards.MVVM.View.AcercaDePage"
             Background="#ECEFF4" av:DesignWidth="396.648">
             
    <!-- Está diseñado como UserControl para ser inyectado en el Dashboard, no como Ventana Independiente -->
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <TextBlock Text="Fothel Cards" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="#2E3440" Margin="0,0,0,40"/>

            <!-- Canvas permite dibujo libre y posicionamiento absoluto. Usado aquí para las animaciones -->
            <Canvas Height="100" Background="Transparent" x:Name="CanvasAnimacion">
                <!-- Texto Base que va a verse afectado por animaciones -->
                <TextBlock x:Name="TxtNombre" 
                           Text="Héctor Fernández" 
                           FontSize="40" 
                           FontWeight="ExtraBold">

                    <!-- Separamos el color del ForeGround para poder animarlo abajo con ColorAnimation -->
                    <TextBlock.Foreground>
                        <SolidColorBrush x:Name="AnimatedBrush" Color="#5E81AC"/>
                    </TextBlock.Foreground>

                    <!-- Disparadores de Animación en estado Loaded (Cuando la pantalla termina de cargar visualmente) -->
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <!-- Storyboard es la grabadora de WPF que guarda los fotogramas clave -->
                                <Storyboard>
                                    <!-- Animación 1: MOVIMIENTO LATERAL -->
                                    <DoubleAnimation 
                                        Storyboard.TargetName="TxtNombre"
                                        Storyboard.TargetProperty="(Canvas.Left)"
                                        From="-300" To="900" 
                                        Duration="0:0:8" 
                                        RepeatBehavior="Forever" 
                                        AutoReverse="True"/> <!-- AutoReverse hace que rebote al llegar al final -->

                                    <!-- Animación 2: CAMBIO DE COLOR (De azul a verde/rojo) -->
                                    <ColorAnimation 
                                        Storyboard.TargetName="AnimatedBrush"
                                        Storyboard.TargetProperty="Color"
                                        From="#5E81AC" To="#BF616A" 
                                        Duration="0:0:4" 
                                        RepeatBehavior="Forever" 
                                        AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </Canvas>

            <TextBlock Text="Proyecto: FothelCards v1.0" HorizontalAlignment="Center" Margin="0,50,0,10"/>

            <!-- Un pequeño botón de vuelta que busca y dispara el método 'MostrarStockCommand' en el árbol visual superior -->
            <Button Content="Cerrar Info / Volver al Panel" 
                    Command="{Binding DataContext.MostrarStockCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                    Background="#BF616A" Foreground="White" 
                    Padding="20,10" HorizontalAlignment="Center" Margin="0,20,0,0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>