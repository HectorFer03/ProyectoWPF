<Page x:Class="FothelCards.MVVM.View.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:FothelCards.MVVM.ViewModel"
      xmlns:view="clr-namespace:FothelCards.MVVM.View"
      Title="DashboardPage">

    <!-- Enlaza esta Vista (XAML) con su controlador (DashboardViewModel) para que los '{Binding Comando}' funcionen -->
    <Page.DataContext>
        <vm:DashboardViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <!-- Diccionario local que le dice al Frame central (ContentControl): 
             "Oye, si el usuario hace clic en el botón de Stock y te llega un objeto WorkspaceViewModel, dibújame encima esta pantalla WorkspacePage" -->
        <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
            <view:WorkspacePage />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:UsuariosViewModel}">
            <view:UsuariosPage />
        </DataTemplate>
        
        <!-- Para la página 'Acerca de', como no necesita base de datos, usa el BaseViewModel genérico para que no falle el casteo -->
        <DataTemplate DataType="{x:Type vm:BaseViewModel}">
            <view:AcercaDePage />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:ConfiguracionViewModel}">
            <view:ConfiguracionPage />
        </DataTemplate>
    </Page.Resources>
    
    <!-- División principal de la pantalla -->
    <Grid Background="#ECEFF4">
        <!-- Tiene 3 filas: Un Header de 60px, el contenido principal (* = restante), y el Footer de 30px -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Cabecera Superior (Fila 0) -->
        <Grid Grid.Row="0" Background="#2E3440">
            <TextBlock Text="FOTHELCARDS" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0"/>

            <!-- Reproductor de música invisible -->
            <MediaElement x:Name="BackgroundAudio" Volume="0.5" Visibility="Collapsed"/>

            <!-- Widget o botón flotante a la derecha para silenciar la música -->
            <view:AudioWidget HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" ToggleAudio="AudioWidget_ToggleAudio"/>
        </Grid>

        <!-- Bloque Central (Fila 1) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/> <!-- Barra lateral izquierda siempre de 220 píxeles fijos -->
                <ColumnDefinition Width="*"/>   <!-- Resto del espacio para inyectar la pantalla seleccionada -->
            </Grid.ColumnDefinitions>

            <!-- Menú LATERAL (Columna 0) -->
            <StackPanel Grid.Column="0" Background="#3B4252">
                <TextBlock Text="MENÚ PRINCIPAL" Foreground="White" FontSize="16" FontWeight="Bold" Margin="20,20,20,10" HorizontalAlignment="Center"/>
                <Separator Margin="10,0,10,20" Background="#4C566A"/>

                <!-- Botones del menú enlazados a sus comandos en DashboardViewModel -->
                <Button Content="Inventario" Command="{Binding MostrarStockCommand}" Margin="10,5" Padding="10"/>
                <Button Content="Configuración (Usuarios)" Command="{Binding MostrarUsuariosCommand}" Margin="10,5" Padding="10"/>
                <Button Content="Acerca de / Info" Command="{Binding MostrarInfoCommand}" Margin="10,5" Padding="10"/>
                <Button Content="Configuración" Command="{Binding MostrarConfiguracionCommand}" Margin="10,5" Padding="10"/>
                
                <!-- Botón de Salir con color rojo (#BF616A) -->
                <Button Content="Salir" Command="{Binding SalirCommand}" Margin="10,5" Padding="10" Background="#BF616A" Foreground="White"/>
            </StackPanel>

            <!-- PÁGINA CENTRAL (Columna 1). El control que dibuja lo que la variable 'VistaActual' dicte -->
            <ContentControl Grid.Column="1" Content="{Binding VistaActual}" Margin="10"/>
        </Grid>

        <Grid Grid.Row="2" Background="#D8DEE9">
            <TextBlock Text="© 2026 FothelCards - Sistema de Gestión" Foreground="#4C566A" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
        </Grid>
    </Grid>
</Page>