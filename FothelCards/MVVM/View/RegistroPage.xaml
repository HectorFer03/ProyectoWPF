<Page x:Class="FothelCards.MVVM.View.RegistroPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:FothelCards.MVVM.ViewModel"
      Title="RegistroPage">

    <!-- Enlaza el XAML con su propio controlador (ViewModel) -->
    <Page.DataContext>
        <vm:RegistroViewModel/>
    </Page.DataContext>

    <!-- Fondo de color sólido como el Login -->
    <Grid Background="#2E3440">
        <!-- Truco de diseño: 3 Columnas Asterisco para empujar el contenido al centro usando proporciones -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>     <!-- Vacío izquierdo -->
            <ColumnDefinition Width="Auto"/>  <!-- El contenido ocupa justo lo que necesita -->
            <ColumnDefinition Width="*"/>     <!-- Vacío derecho -->
        </Grid.ColumnDefinitions>

        <!-- Contenedor central gris oscuro -->
        <Border Grid.Column="1" Background="#3B4252" Padding="25" CornerRadius="10" VerticalAlignment="Center">
            <StackPanel Width="250">
                <TextBlock Text="REGISTRO" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <!-- Etiqueta Binding de feedback (Rojo normalmente) -->
                <TextBlock Text="{Binding Mensaje}" Foreground="#EBCB8B" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center" TextWrapping="Wrap"/>

                <!-- Agrupación de título + campo de texto vinculados al Binding del RegisterViewModel -->
                <TextBlock Text="Email:" Foreground="White" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Email}" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Usuario:" Foreground="White" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username}" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Contraseña:" Foreground="White" Margin="0,0,0,5"/>
                <!-- Se nombra el PasswordBox nativo de WPF para mandarlo limpio por parámetro sin exponerlo en texto plano -->
                <PasswordBox x:Name="CajaPasswordReg" Margin="0,0,0,20" Padding="5"/>

                <!-- Botón Principal: Ejecuta proceso asíncrono en BBDD -->
                <Button Content="Confirmar Registro" 
                        Command="{Binding RegistrarCommand}" 
                        CommandParameter="{Binding ElementName=CajaPasswordReg}"
                        Background="#81A1C1" Foreground="White" Padding="8" Margin="0,0,0,10"/>

                <!-- Botón Auxiliar: Navega atrás sin guardar -->
                <Button Content="Volver al Login" 
                        Command="{Binding VolverCommand}" 
                        Background="#BF616A" Foreground="White" Padding="8"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>