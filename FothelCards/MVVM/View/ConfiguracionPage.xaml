<UserControl x:Class="FothelCards.MVVM.View.ConfiguracionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FothelCards.MVVM.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Fila 0: Titulo superior -->
            <RowDefinition Height="*"/>    <!-- Fila 1: Todo el panel en caja blanca del medio -->
            <RowDefinition Height="Auto"/> <!-- Fila 2: Botonera inferior -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configuración del Sistema" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" Padding="20" CornerRadius="8" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <Border.Effect>
                <!-- Sombra estética -->
                <DropShadowEffect ShadowDepth="1" Color="#E0E0E0" Opacity="0.3" BlurRadius="10"/>
            </Border.Effect>

            <StackPanel HorizontalAlignment="Left" Width="450">
                <!-- Se dibuja el texto verde cuando se guarda (Feedback visual al usuario de éxito/error) -->
                <TextBlock Text="{Binding Mensaje}" Foreground="#A3BE8C" FontWeight="Bold" Margin="0,0,0,15" TextWrapping="Wrap"/>

                <TextBlock Text="Resolución de Ventana:" FontWeight="Bold" Margin="0,5,0,5"/>
                <!-- El ComboBox llena sus opciones de la ObservableCollection de C#, pero el valor elegido cae en 'Configuracion.Resolucion' -->
                <ComboBox ItemsSource="{Binding OpcionesResolucion}" SelectedItem="{Binding Configuracion.Resolucion}" Padding="5"/>

                <TextBlock Text="Nivel de Complejidad (Modo de Uso):" FontWeight="Bold" Margin="0,15,0,5"/>
                <!-- Idem, opciones de UI pero Binding de valor persistente -->
                <ComboBox ItemsSource="{Binding OpcionesModo}" SelectedItem="{Binding Configuracion.ModoUso}" Padding="5"/>

                <TextBlock Text="Control de Volumen:" FontWeight="Bold" Margin="0,15,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>     <!-- Barra de Deslizamiento (Slider) -->
                        <ColumnDefinition Width="Auto"/>  <!-- El Texto estático del % de volumen -->
                    </Grid.ColumnDefinitions>
                    
                    <!-- IsSnapToTickEnabled="True" evita fracciones flotantes raras obligando a saltos de porcentaje redondos -->
                    <Slider Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding Configuracion.Volumen}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Cursor="Hand"/>
                    <!-- El StringFormat añade de adorno el símbolo de % después del número -->
                    <TextBlock Grid.Column="1" Text="{Binding Configuracion.Volumen, StringFormat={}{0}%}" Margin="15,0,0,0" Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Text="Opciones Extra:" FontWeight="Bold" Margin="0,15,0,5"/>
                <CheckBox Content="Silenciar audio de fondo (Toggle)" IsChecked="{Binding Configuracion.SilenciarAudio}" Margin="0,5" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <!-- Botón Volver (Actualmente redundante ya que el Dashboard izquierdo gestiona por donde se mueve, se dejó por si luego quieren usarlo independiente de nuevo) -->
            <Button Content="Cancelar / Volver" Command="{Binding VolverCommand}" Background="#BF616A" Foreground="White" Padding="15,8" Margin="0,0,10,0" Cursor="Hand"/>
            <!-- Manda guardar todo a config.json -->
            <Button Content="Guardar Configuración" Command="{Binding GuardarCommand}" Background="#A3BE8C" Foreground="Black" FontWeight="Bold" Padding="15,8" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
