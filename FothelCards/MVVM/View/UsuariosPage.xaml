<UserControl x:Class="FothelCards.MVVM.View.UsuariosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:FothelCards.MVVM.ViewModel">

    <!-- Margen Global para que no se pegue a los bordes del Dashboard principal -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Título -->
            <RowDefinition Height="Auto"/> <!-- Fila del formulario de Nuevo Usuario -->
            <RowDefinition Height="*"/>    <!-- Resto de la pantalla para la tabla de usuarios -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gestión de Empleados" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Formulario (Fila 1) -->
        <Border Grid.Row="1" Background="#D8DEE9" Padding="15" Margin="0,0,0,20" CornerRadius="5">
            <!-- StackPanel Horizontal hace que todos los TextBox y Botones se pongan uno al lado de otro de Izquierda a Derecha -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Usuario:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                <TextBox Text="{Binding NuevoUsername}" Width="120" Margin="0,0,15,0" Padding="5"/>

                <TextBlock Text="Contraseña:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                <TextBox Text="{Binding NuevoPassword}" Width="120" Margin="0,0,15,0" Padding="5"/>

                <TextBlock Text="Rol:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                <!-- Desplegable enlazado a la variable NuevoRol del ViewModel -->
                <ComboBox SelectedValue="{Binding NuevoRol}" Width="120" Margin="0,0,15,0" Padding="5" SelectedValuePath="Content">
                    <ComboBoxItem Content="Empleado" IsSelected="True"/>
                    <ComboBoxItem Content="Administrador"/>
                </ComboBox>

                <!-- Botón de guardado. Llama a 'AgregarUsuarioCommand' configurado en 'UsuariosViewModel.cs' -->
                <Button Content="Agregar Usuario" Command="{Binding AgregarUsuarioCommand}" Background="#A3BE8C" FontWeight="Bold" Padding="10"/>
            </StackPanel>
        </Border>

        <!-- Tabla de Datos (Fila 2) -->
        <!-- ItemsSource="{Binding ListaUsuarios}" es lo que hace la magia de rellenar la tabla solita con el MySQL -->
        <!-- AutoGenerateColumns="False": Evitamos que dibuje las columnas como le dé la gana, las definimos nosotros debajo manualmente -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding ListaUsuarios}" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <!-- Cada Columna se enlaza textualmente (Binding) con el nombre de la Propiedad en la clase 'UsuarioModel.cs' -->
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Nombre de Usuario" Binding="{Binding Nombre}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="100" IsReadOnly="True"/>

                <!-- Columna personalizada para meter un botón dentro de la celda en lugar de un texto -->
                <DataGridTemplateColumn Header="Acciones" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- Funciona igual que en Catálogo: Manda por parámetro al botón de borrar LA FILA ENTERA ('{Binding}') a la que pertenece ese botón -->
                            <Button Content="Eliminar" 
                                    Command="{Binding DataContext.EliminarUsuarioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}"
                                    Background="#BF616A" Foreground="White" Padding="5" Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>