<Page x:Class="FothelCards.MVVM.View.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:FothelCards.MVVM.ViewModel"
      Title="LoginPage">

    <!-- Enlaza el XAML con su cerebro: LoginViewModel -->
    <Page.DataContext>
        <vm:LoginViewModel/>
    </Page.DataContext>

    <!-- Fondo de pantalla gris oscuro/azulado -->
    <Grid Background="#2E3440">
        <!-- Caja centrada vertical y horizontalmente que contendrá el formulario de inicio de sesión.
             Se deshabilita visualmente (IsEnabled=False) si el ViewModel lo pide (para evitar clicks múltiples mientras carga) -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="250" IsEnabled="{Binding IsUiEnabled}">
            <TextBlock Text="FOTHELCARDS" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <!-- Etiqueta de Feedback: Aquí saldrán en rojo los errores como "Contraseña incorrecta" o "Usuario en uso" -->
            <TextBlock Text="{Binding Mensaje}" Foreground="#BF616A" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center" TextWrapping="Wrap"/>

            <TextBlock Text="Usuario / Email:" Foreground="White" Margin="0,0,0,5"/>
            <!-- Campo unido bidireccionalmente a la variable 'Username' del ViewModel -->
            <TextBox Text="{Binding Username}" Margin="0,0,0,15" Padding="5"/>

            <TextBlock Text="Contraseña:" Foreground="White" Margin="0,0,0,5"/>
            <!-- El componente PasswordBox oculta los caracteres tipeados por razones de seguridad.
                 A diferencia del TextBox, WPF no permite hacer Binding directo a su texto en texto claro,
                 por lo que le asignamos un nombre 'x:Name' para enviarle el control entero al botón debajo -->
            <PasswordBox x:Name="CajaPassword" Margin="0,0,0,20" Padding="5"/>

            <!-- Botones que detonan las acciones preparadas en LoginViewModel.cs -->
            <!-- Al hacer Login, le pasamos 'CajaPassword' por parámetro para que el ViewModel extraiga de ahí el texto y lo encripte -->
            <Button Content="Iniciar Sesión" 
                Command="{Binding LoginCommand}" 
                CommandParameter="{Binding ElementName=CajaPassword}" 
                Background="#A3BE8C" Foreground="Black" Padding="8" Margin="0,0,0,10"/>
                
            <Button Content="Registrarse" Command="{Binding IrRegistroCommand}" Background="#81A1C1" Foreground="White" Padding="8" Margin="0,0,0,10"/>
            <Button Content="Recuperar Contraseña" Command="{Binding RecuperarPasswordCommand}" Background="#EBCB8B" Foreground="Black" Padding="8" Margin="0,0,0,10"/>
            
            <!-- Botón opcional para testing para entrar sin permisos de escritura en la db (solo vistas) -->
            <Button Content="Modo Invitado" Command="{Binding BypassCommand}" Background="#4C566A" Foreground="White" Padding="8"/>
        </StackPanel>
    </Grid>
</Page>