<UserControl x:Class="FothelCards.MVVM.View.AudioWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
             
    <!-- Este es un Control de Usuario Personalizado (Custom Control).
         Se creo para poder reusar este botón de muteado de música en cualquier pantalla sin tener que copiar y pegar este código. -->
    <Button x:Name="BtnMute" Content="Silenciar Audio" Click="BtnMute_Click" 
            Background="#EBCB8B" Foreground="Black" Padding="10,5" FontWeight="Bold"/>
</UserControl>