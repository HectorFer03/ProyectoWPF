<UserControl x:Class="FothelCards.MVVM.View.WorkspacePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:FothelCards.MVVM.ViewModel">
    
    <!-- Diccionario de estilos exclusivo de esta Pestaña (no afecta a App.xaml) -->
    <UserControl.Resources>
        <!-- Estilo para las Cajas Blancas Tipo "PanelContenedor" sombra y esquinas redondeadas -->
        <Style x:Key="PanelContainer" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <!-- Efecto de sombreado gris -->
                    <DropShadowEffect ShadowDepth="1" Color="#E0E0E0" Opacity="0.3" BlurRadius="10"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Estilo global para los textos grandes de cabecera -->
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10,0,0,10"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
    </UserControl.Resources>

    <!-- La página se divide en 2 Columnas -->
    <Grid Background="#F4F7F6" Margin="10">
        <Grid.ColumnDefinitions>
            <!-- Columna 0 (Catálogo): Ocupa 3 partes de la pantalla (Más grande) -->
            <ColumnDefinition Width="3*"/>
            <!-- Columna 1 (Panel Edición Derecha): Ocupa 2 partes -->
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ZONA IZQUIERDA: LISTA DE PRODUCTOS -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/> <!-- La lista cogerá todo el espacio restante -->
            </Grid.RowDefinitions>

            <!-- Titulo Aplicando el Estilo 'TitleText' predefinido arriba -->
            <TextBlock Text="Inventario de Tienda" Style="{StaticResource TitleText}" Grid.Row="0"/>

            <!-- Panel de opciones manuales para la distribución de la tabla -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,0,10">
                <TextBlock Text="Filas:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding Filas}" Width="40" Margin="0,0,15,0" TextAlignment="Center"/>
                <TextBlock Text="Columnas:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding Columnas}" Width="40" Margin="0,0,15,0" TextAlignment="Center"/>
                <Button Content="Actualizar Estanterías" Command="{Binding GenerarCommand}" Padding="5,2" Background="#D6EAF8" Foreground="#21618C"/>
            </StackPanel>

            <!-- Lista visual en cuadrícula de las cartas -->
            <Border Style="{StaticResource PanelContainer}" Grid.Row="2">
                <!-- Por si hay muchas cartas y se sale de la pantalla, que aparezca una barra para hacer scroll -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <!-- ItemsControl dibuja la 'ListaProductos' del Viewmodel iterándola una a una -->
                    <ItemsControl ItemsSource="{Binding ListaProductos}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- Se dibujan en modo UniformGrid usando los Bindings de columnas y filas superior -->
                                <UniformGrid Rows="{Binding Filas}" Columns="{Binding Columnas}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <!-- Por cada carta en 'ListaProductos', ¿Cómo se dibuja visualmente? -->
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Cada carta es un gran botón invisible. Al pulsarlo ejecuta SeleccionarCommand, pasando toda la fila de la carta '{Binding}' como parámetro -->
                                <Button Margin="5" Command="{Binding DataContext.SeleccionarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0">
                                    <Border Background="#EAF2F8" CornerRadius="8" Padding="10">
                                        <StackPanel>
                                            <Image Source="{Binding RutaPortada}" Height="100" Margin="0,0,0,5" />
                                            <TextBlock Text="{Binding Nombre}" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Estado}" TextAlignment="Center" Foreground="#555" FontSize="11" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PanelContainer}" Grid.Row="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Detalle Seleccionado" Style="{StaticResource TitleText}" FontSize="18"/>

                        <Image Source="{Binding ProductoSeleccionado.RutaPortada}" Height="120" Margin="0,5"/>

                        <TextBlock Text="Nombre del producto:" Foreground="#555" FontSize="11" Margin="0,5,0,0"/>
                        <TextBox Text="{Binding ProductoSeleccionado.Nombre, UpdateSourceTrigger=PropertyChanged}" 
                     FontWeight="Bold" FontSize="16" TextAlignment="Center" Margin="0,2" Padding="5"/>

                        <TextBlock Text="Tipo de producto:" Foreground="#555" FontSize="11" Margin="0,5,0,0"/>
                        <ComboBox SelectedValue="{Binding ProductoSeleccionado.Tipo, UpdateSourceTrigger=PropertyChanged}" 
                      Margin="0,2" Padding="5" SelectedValuePath="Content">
                            <ComboBoxItem Content="Comic/Manga"/>
                            <ComboBoxItem Content="Carta Coleccionable"/>
                            <ComboBoxItem Content="Figura"/>
                        </ComboBox>

                        <Button Content="{Binding ProductoSeleccionado.Estado}" 
                            Command="{Binding CambiarEstadoCommand}" CommandParameter="{Binding ProductoSeleccionado}"
                            Margin="0,10" Padding="8" Background="Gold" Cursor="Hand" FontWeight="Bold"/>

                        <UniformGrid Columns="2" Margin="0,5">
                            <Button Content="Guardar" Command="{Binding EditarProductoCommand}" 
                        Background="#5E81AC" Foreground="White" Padding="8" Margin="0,0,5,0" Cursor="Hand"/>
                            <Button Content="Eliminar" Command="{Binding EliminarProductoCommand}" 
                        Background="#BF616A" Foreground="White" Padding="8" Margin="5,0,0,0" Cursor="Hand"/>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Style="{StaticResource PanelContainer}" Grid.Row="1" AllowDrop="True" Drop="Grid_Drop" Background="#FDFEFE">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Agregar Nuevo" Style="{StaticResource TitleText}" FontSize="18"/>

                        <Image Source="{Binding NuevaRutaPortada}" Height="120" Margin="0,5"/>
                        <Button Content="Buscar Portada (o Arrastrar imagen aquí)" Click="BtnBuscarImagen_Click" 
                    Margin="0,0,0,10" Padding="5" Background="#E5E7E9" Cursor="Hand" FontSize="11"/>

                        <TextBlock Text="Nombre del producto:" Foreground="#555" FontSize="11" Margin="0,5,0,0"/>
                        <TextBox Text="{Binding NuevoNombre, UpdateSourceTrigger=PropertyChanged}" 
                     FontWeight="Bold" FontSize="16" TextAlignment="Center" Margin="0,2" Padding="5"/>

                        <TextBlock Text="Tipo de producto:" Foreground="#555" FontSize="11" Margin="0,5,0,0"/>
                        <ComboBox SelectedValue="{Binding NuevoTipo, UpdateSourceTrigger=PropertyChanged}" 
                      Margin="0,2" Padding="5" SelectedValuePath="Content">
                            <ComboBoxItem Content="Comic/Manga"/>
                            <ComboBoxItem Content="Carta Coleccionable"/>
                            <ComboBoxItem Content="Figura"/>
                        </ComboBox>

                        <Button Content="Guardar Coleccionable" Command="{Binding AgregarProductoCommand}" 
                    Background="#A3BE8C" Foreground="White" Padding="10" Margin="0,15,0,5" 
                    FontWeight="Bold" Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>